{% extends 'base.html.tera' %}
{% block title %}Field Notes — Riley Seaburg{% endblock title %}
{% block head %}{{ super() }}{% include 'sections/editorial_head.html.tera' %}<link rel="stylesheet" href="/css/blog.css">{% endblock head %}
{% block content %}
<main class="journal">
  <header class="journal-hero wrap">
    <p class="eyebrow">Riley Seaburg / Field notes</p>
    <h1>Build things that<br><em>hold up.</em></h1>
    <div class="hero-footer"><p>Essays on software, autonomous agents, work, and the lessons that survive contact with reality.</p><span>{{ posts | length }} dispatches · Boise, Idaho</span></div>
  </header>
  <section class="journal-list wrap" aria-label="Published articles">
    {% for post in posts %}
    {% set date = post.publish_date | default(value="") | split(pat=" ") %}
    {% set topic = post.category | default(value="Field note", boolean=true) %}
    <article class="journal-entry">
      <a class="entry-link" href="/posts/{{ post.slug }}" aria-label="Read {{ post.title }}">
        <span class="entry-number">{{ loop.index }}</span>
        <div class="entry-copy">
          <div class="entry-meta"><time datetime="{{ date | first | default(value='') }}">{{ date | first | default(value='Undated') }}</time><span>{{ topic }}</span></div>
          <h2>{{ post.title | default(value="Untitled", boolean=true) | replace(from="â€™", to="’") | replace(from="â€œ", to="“") | replace(from="â€", to="”") }}</h2>
          <p>{{ post.content | default(value="", boolean=true) | markdown | striptags | truncate(length=220) }}</p>
        </div>
        <span class="entry-arrow" aria-hidden="true">↗</span>
      </a>
    </article>
    {% else %}<p class="journal-empty">No dispatches yet. Check back soon.</p>{% endfor %}
  </section>
  <footer class="journal-signoff wrap"><span>End of notes</span><a href="/">Back to rileyseaburg.com</a></footer>
</main>
{% endblock content %}
