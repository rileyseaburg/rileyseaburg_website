{% extends 'base.html.tera' %}
{% import 'macros/editorial_post.html.tera' as editorial %}
{% block title %}{{ post.title }} — Riley Seaburg{% endblock title %}
{% block description %}{{ post.content | default(value="", boolean=true) | markdown | striptags | truncate(length=155) }}{% endblock description %}
{% block head %}{{ super() }}{% include 'sections/editorial_head.html.tera' %}<link rel="stylesheet" href="/css/post.css">{% endblock head %}
{% block content %}
{% set date = post.publish_date | default(value="") | split(pat=" ") | first | default(value="") %}
{{ editorial::render(title=post.title, content=post.content, author=post.author, category=post.category, date=date) }}
{% endblock content %}
