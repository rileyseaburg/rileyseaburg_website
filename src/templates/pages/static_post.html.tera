{% extends 'base.html.tera' %}
{% import 'macros/editorial_post.html.tera' as editorial %}
{% block title %}{{ title }} — Riley Seaburg{% endblock title %}
{% block description %}{{ content | markdown | striptags | truncate(length=155) }}{% endblock description %}
{% block head %}{{ super() }}{% include 'sections/editorial_head.html.tera' %}<link rel="stylesheet" href="/css/post.css">{% endblock head %}
{% block content %}
{{ editorial::render(title=title, content=content, author=author | default(value="Riley Seaburg"), category=category | default(value="Engineering note"), date=publish_date | default(value="")) }}
{% endblock content %}
